# ============================================================
# Image Intelligentsia — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to git.
#
# For local development, the Replit environment sets these
# automatically. For Vercel + Neon, set them in the Vercel
# project dashboard under Settings → Environment Variables.
# ============================================================

# ── Database (Neon) ─────────────────────────────────────────
# Get this from your Neon project dashboard.
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host/image-intelligentsia?sslmode=require

# Individual connection parts (optional, Drizzle uses DATABASE_URL)
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=

# ── App ─────────────────────────────────────────────────────
# Secret used to sign JWT tokens (generate a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=https://image-intelligentsia.vercel.app

# ── Frontend (Vercel sets this via vercel.json) ──────────────
# Base URL path — set to "/" for Vercel root deployment
BASE_PATH=/

# ── Dev server only ─────────────────────────────────────────
# Only needed when running locally (Replit sets this automatically)
PORT=3000
