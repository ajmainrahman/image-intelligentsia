# ============================================================
# Career Hub — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to git.
#
# For Vercel + Neon, add these in the Vercel project dashboard:
#   Settings → Environment Variables
# ============================================================

# ── Database (Neon) ──────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details.
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host/careerhub?sslmode=require

# ── Auth secret ──────────────────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# ── CORS (optional) ──────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all).
# Example: https://yourapp.vercel.app,https://yourcustomdomain.com
ALLOWED_ORIGINS=

# ── Dev server only ──────────────────────────────────────────
# Only needed when running locally (not required on Vercel).
PORT=3000
BASE_PATH=/
