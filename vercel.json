{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/career-hub run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
